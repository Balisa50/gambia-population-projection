# Data — raw downloads can be large and have their own licences; keep out of git.
# Commit small processed/reference tables deliberately if needed.
# Raw downloads are ignored by default (large, own licences), BUT we commit the
# small Gambia WPP extracts so the repo is self-contained and reproducible.
data/raw/*
data/external/*
!**/.gitkeep
!data/raw/wpp2024/
data/raw/wpp2024/*
!data/raw/wpp2024/*.tsv
!data/raw/wpp2024/_manifest.json

# Python
__pycache__/
*.py[cod]
.ipynb_checkpoints/
.venv/
env/
venv/
*.egg-info/

# Conda
.conda/

# MCMC traces / large artifacts
*.nc
*.netcdf
arviz_data/
*.pkl

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Reports build artifacts
*.aux
*.log
*.out
reports/_build/
